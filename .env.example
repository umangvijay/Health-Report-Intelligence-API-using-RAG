# ============================================================
# AI Doctor - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
# Do NOT commit .env to version control.
# ============================================================

# ============ HUGGINGFACE ============
# Get token at: https://huggingface.co/settings/tokens
# Required permissions: "Read" + "Inference API"
HF_TOKEN=YOUR_HF_TOKEN_HERE

# ============ GEMINI (OPTIONAL) ============
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ============ OPEN FDA (OPTIONAL) ============
# Get key at: https://open.fda.gov/apis/authentication/
OPEN_FDA_API_KEY=YOUR_OPEN_FDA_API_KEY_HERE

# ============ LLM PROVIDER ============
# Options: auto | gemini | hf | local
# auto = Gemini first -> HF -> local (default)
LLM_PROVIDER=auto

# ============ SERVER ============
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=False

# ============ GPU ============
USE_GPU=True

# ============ DATA PATHS ============
AI_DOCTOR_DATA_DIR=./ai_doctor_data
HF_HOME=./ai_doctor_data/huggingface_cache
HF_DATASETS_CACHE=./ai_doctor_data/datasets
TRANSFORMERS_CACHE=./ai_doctor_data/models
