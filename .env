# API Configuration
API_HOST=127.0.0.1
API_PORT=3000
DEBUG=False

# ============ HUGGINGFACE (HIGH PRIORITY - use for answers) ============
# Uncomment and set so HF is used (priority: Gemini first, then HF, then local).
# Get token at: https://huggingface.co/settings/tokens → "Read" + "Inference API"
HF_TOKEN=YOUR_API_KEY
USE_GPU=True

# HuggingFace API - NEW URL (old one deprecated in 2026)
HF_API_BASE=https://router.huggingface.co/hf-inference/models

# ============ GEMINI (OPTIONAL) ============
# Can work WITHOUT Gemini - all HF models will be used instead
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your api key

# ============ OPEN FDA (OPTIONAL - DRUG DATA) ============
# Get key at: https://open.fda.gov/apis/authentication/
# Higher limits with key: 120,000 requests/day per key
OPEN_FDA_API_KEY=your api key

# ============ LLM PROVIDER (ALWAYS USE) ============
# Options: auto | gemini | hf | local
# auto = Gemini first → HF → local (default)
# gemini = Always use Gemini only (fallback to local if fail)
# hf = Always use HuggingFace only (fallback to local if fail)
# local = Always use local/rule-based only
LLM_PROVIDER=auto

# ============ SPEED: Use HF API only (no local model load = faster) ============
USE_HF_API_ONLY=1

# ============ DATA PATHS (D: DRIVE) ============
# All data on D: to save C: space. Run transfer_ml_data_c_to_d.py once to move cache.
AI_DOCTOR_DATA_DIR=D:\c++ homework\python\ai doctor dataset
HF_HOME=D:\c++ homework\python\ai doctor dataset\huggingface_cache
HF_DATASETS_CACHE=D:\c++ homework\python\ai doctor dataset\datasets
TRANSFORMERS_CACHE=D:\c++ homework\python\ai doctor dataset\models

# ============ DATABASE ============
DATABASE_URL=sqlite:///D:/c++ homework/python/ai doctor dataset/ai_doctor.db

# PostgreSQL (optional, for production)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ai_doctor
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# ============ MODEL PATHS ============
INTENT_MODEL_PATH=emilyalsentzer/Bio_ClinicalBERT
MEDICAL_MODEL_PATH=ncbi/MedCPT-Query-Encoder
VISION_MODEL_PATH=microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224
